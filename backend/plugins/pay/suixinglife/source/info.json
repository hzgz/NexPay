{
    "name": "suixinglife",
    "title": "随行付会生活",
    "author": "官方",
    "link": "https://www.suixingpay.com/",
    "version": "1.1",
    "icon": "suixingpay.png",
    "desc": "",
    "pay_types": [
        "alipay",
        "wxpay",
        "bank"
    ],
    "inputs": {
        "username": {
            "name": "登录账号",
            "type": "input",
            "required": true,
            "note": "商编/手机号/门店编号"
        },
        "password": {
            "name": "登录密码",
            "type": "input",
            "required": true,
            "note": "登录密码"
        },
        "mno": {
            "name": "商户编号",
            "type": "input",
            "note": "多商户账号时必填，单商户可留空"
        }
    },
    "note": "<p>需添加守护进程，运行目录：<u>[basedir]plugins/payment/suixinglife/</u> 启动命令：<u>php server.php</p>",
    "bindwxmp": false,
    "bindwxa": false
}
