{
    "name": "qqpay",
    "title": "QQ钱包官方支付",
    "author": "官方",
    "link": "https://mp.qpay.tenpay.com/",
    "version": "1.1",
    "icon": "qqpay.png",
    "desc": "",
    "pay_types": [
        "qqpay"
    ],
    "trans_types": [
        "qqpay"
    ],
    "inputs": {
        "appid": {
            "name": "QQ钱包商户号",
            "type": "input",
            "required": true,
            "note": ""
        },
        "appkey": {
            "name": "QQ钱包API密钥",
            "type": "input",
            "required": true,
            "note": ""
        },
        "appurl": {
            "name": "操作员账号",
            "type": "input",
            "note": "仅资金下发（如退款、企业付款）时需要"
        },
        "appmchid": {
            "name": "操作员密码",
            "type": "input",
            "note": "仅资金下发（如退款、企业付款）时需要"
        },
        "sslcert_path": {
            "name": "商户证书",
            "type": "upload",
            "accept": ".pem",
            "note": "apiclient_cert.pem，仅退款、企业付款需要"
        },
        "sslkey_path": {
            "name": "商户证书私钥",
            "type": "upload",
            "accept": ".pem",
            "note": "apiclient_key.pem，仅退款、企业付款需要"
        }
    },
    "select": {
        "1": "扫码支付(包含H5)",
        "2": "公众号支付"
    },
    "note": "<p>如需资金下发（如退款、企业付款）功能，请上传<a href=\"https://mp.qpay.tenpay.com/buss/wiki/206/1213\" target=\"_blank\" rel=\"noreferrer\">API证书</a>，并填写<a href=\"https://kf.qq.com/faq/170112AZ7Fzm170112VNz6zE.html\" target=\"_blank\" rel=\"noreferrer\">操作员账号和密码</a></p>",
    "bindwxmp": false,
    "bindwxa": false
}