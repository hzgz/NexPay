{
    "code": "paypro",
    "name": "超级支付",
    "version": "1.0",
    "description": "超级支付，已从 epay_pro 支付插件目录迁移至 NexPay 插件体系。",
    "group": "pay",
    "kind": "gateway",
    "payment_methods": [
        "alipay",
        "wechat",
        "qqpay",
        "unionpay",
        "douyin",
        "jdpay",
        "paypal"
    ],
    "capabilities": [
        "create",
        "query",
        "notify"
    ],
    "provider": "plugins\\pay\\paypro\\PluginProvider"
}
