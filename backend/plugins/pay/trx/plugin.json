{
    "code": "trx",
    "name": "TRX支付(TRON)",
    "version": "1.0.0",
    "description": "TRON 链上 TRX 收款插件，支持监控与自动补单。",
    "group": "pay",
    "kind": "chain",
    "payment_methods": [
        "trx"
    ],
    "capabilities": [
        "address_match",
        "chain_confirm",
        "notify",
        "daemon"
    ],
    "provider": "plugins\\pay\\trx\\PluginProvider"
}
