APP_NAME="EPay Plus"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://127.0.0.1:5174
HTTP_PORT=5174

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=epay_plus
DB_USERNAME=root
DB_PASSWORD=123456
DB_PREFIX=

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

TOKEN_SECRET=PLEASE_CHANGE_TO_A_RANDOM_32_PLUS_CHAR_SECRET
INTERNAL_REFUND_SECRET=PLEASE_CHANGE_TO_A_RANDOM_32_PLUS_CHAR_SECRET
SESSION_DRIVER=redis
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=Lax
SESSION_NAME=NEXPAYSESSID
SESSION_PREFIX=nexpay_session_
SESSION_REDIS_DB=1
SECURITY_MAX_BODY_BYTES=2097152
SECURITY_RATE_WINDOW=60
SECURITY_RATE_LIMIT=240
SECURITY_IP_WHITELIST=
SECURITY_IP_BLACKLIST=
OPENAPI_V2_MAX_SKEW_SECONDS=300
OPENAPI_V2_REPLAY_TTL_SECONDS=600
OPENAPI_REPLAY_PREFIX=nexpay:openapi:replay:
SOFTWARE_COMPAT_REQUIRE_TIMESTAMP=false
SOFTWARE_COMPAT_REQUIRE_SIGN=false
SOFTWARE_COMPAT_REPLAY_PROTECTION=false
SOFTWARE_COMPAT_MAX_SKEW_SECONDS=300
SOFTWARE_COMPAT_REPLAY_TTL_SECONDS=600
QUEUE_PREFIX=epay_plus:
PLATFORM_PUBLIC_KEY=
PLATFORM_PRIVATE_KEY=
